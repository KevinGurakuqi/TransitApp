# Copy this file to .env and fill in your keys. Never commit .env to git.

# Required: Google Maps API key (Maps JavaScript API, Directions API, Geocoding API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional: Uber API tokens for real ride-share price estimates (leave empty to use calculated estimates)
UBER_SERVER_TOKEN=
UBER_OAUTH_TOKEN=
